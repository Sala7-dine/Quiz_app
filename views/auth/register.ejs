<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/register.css">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
    <title>Register</title>
</head>

<body>
    <div class="container">
        <p class="title">Sign Up</p>
                <form id="registerForm">

               <!-- Username -->
        <div class="div-utilisateur">
            <span class="span-utilisateur">Entrez Votre Nom d'Utilisateur</span>
            <span class="material-symbols-outlined icon-left">
                account_circle
            </span>
            <input name="username" class="input-utilisateur" type="text" placeholder="Exemple: Fouad" required>
            <p class="error-input-utilisateur" style="display:none; color:red;">Nom Utilisateur Incorrect</p>
        </div>

        <!-- Email -->
        <div class="div-email">
            <span class="span-email">Entrez Votre Email</span>
            <span class="material-symbols-outlined icon-left">
                mail
            </span>
            <input name="email" class="input-email"  type="email" placeholder="Exemple: Fouad@gmail.com" required>
            <p class="error-input-email" style="display:none; color:red;">Ce Email Déjà Utilisé</p>
        </div>

        <!-- Password -->
        <div class="div-password">
            <span class="span-password">Entrez Votre Mot De Passe</span>

            <!-- lock icon left -->
            <span class="material-symbols-outlined icon-left">
                lock
            </span>

            <input class="input-password" name="password" type="password" placeholder="●●●●●●●●●●" required>

            <!-- visibility icon right -->
            <span class="material-symbols-outlined icon-right">
                visibility
            </span>

            <p class="div-erreur-password" style="display:none; color:red;">
                Erreur lors de l'inscription
            </p>
        </div>

        <button type="submit" class="btn-creer-compte">Créer Compte</button>
        </form>
        
        <div style="text-align: center; margin-top: 20px;">
          <p style="color: #666;">Vous avez déjà un compte ? 
            <a href="/auth/login" style="color: #007bff; text-decoration: none; font-weight: 500;">Se connecter</a>
          </p>
          <a href="/" style="color: #666; text-decoration: none; font-size: 14px;">← Retour à l'accueil</a>
        </div>
        
        <script>
        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const errorDiv = document.querySelector('.div-erreur-password');
            const emailError = document.querySelector('.error-input-email');
            
            try {
                const response = await fetch('/auth/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        username: formData.get('username'),
                        email: formData.get('email'),
                        password: formData.get('password')
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    window.location.href = '/';
                } else {
                    if (data.message.includes('email')) {
                        emailError.textContent = data.message;
                        emailError.style.display = 'block';
                    } else {
                        errorDiv.textContent = data.message;
                        errorDiv.style.display = 'block';
                    }
                }
            } catch (error) {
                errorDiv.textContent = 'Erreur d\'inscription';
                errorDiv.style.display = 'block';
            }
        });
        </script>
     

        <p class="p-question-avoir-compte">
            Vous Avez Déjà Un Compte?
            <a href="login">Sign in</a>
        </p>
    </div>
</body>
</html>
