<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JSQuizStarter - Quiz Interactif</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
<header class="header">
    <h1 class="logo">JSQuizStarter</h1>
    <nav class="nav">
        <a href="/dashboard" class="dashboard-link">📊 Dashboard</a>
    </nav>
</header>

<main class="main-content">

    <div class="cards-container">

        <% if(themes) { %>

            <% themes.forEach(theme => { %>

                <div class="card">
                    <h3> <%= theme.titre %> </h3>
                    <p> <%= theme.description %> </p>
                    <form action="/quiz/questions" method="GET">
                        <button id="btn-choice" type="submit" name="choice" class="btn-choice" value="<%= theme.id %>">Choisir</button>
                    </form>
                </div>

            <% }); %>

        <% } %>

    </div>

    <div id="result" class="result" style="display: none;">
        <h2>🎉 Quiz Terminé !</h2>

        <div class="result-summary">
            <div class="result-stat">
                <div class="result-stat-value" id="score">0</div>
                <div class="result-stat-label">Score</div>
            </div>
            <div class="result-stat">
                <div class="result-stat-value" id="globalTime">00:00</div>
                <div class="result-stat-label">Temps total</div>
            </div>
            <div class="result-stat">
                <div class="result-stat-value" id="percentage">0%</div>
                <div class="result-stat-label">Réussite</div>
            </div>
        </div>

        <div class="actions">
            <button class="btn" onclick="location.reload()">Rejouer</button>
            <a href="/dashboard" class="btn">Voir le Dashboard</a>
        </div>

        <h3 style="margin: 32px 0 16px 0; font-size: 18px; font-weight: 600;">Détail des réponses :</h3>
    </div>
</main>

</body>
</html>
