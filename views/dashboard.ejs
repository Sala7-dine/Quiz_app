<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - JSQuizStarter</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 20px;
        }
        
        .dashboard-card {
            background: white;
            border: 1px solid hsl(214.3 31.8% 91.4%);
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        }
        
        .dashboard-card h3 {
            margin-bottom: 15px;
            color: hsl(222.2 84% 4.9%);
            border-bottom: 2px solid hsl(222.2 47.4% 11.2%);
            padding-bottom: 10px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }
        
        .stat-item {
            background: hsl(0 0% 98%);
            padding: 15px;
            border-radius: 6px;
            text-align: center;
        }
        
        .stat-value {
            font-size: 24px;
            font-weight: bold;
            color: hsl(222.2 47.4% 11.2%);
            margin-bottom: 5px;
        }
        
        .stat-label {
            font-size: 14px;
            color: hsl(215.4 16.3% 46.9%);
        }
        
        .history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            border-bottom: 1px solid hsl(214.3 31.8% 91.4%);
        }
        
        .history-item:last-child {
            border-bottom: none;
        }
        
        .leaderboard-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            border-bottom: 1px solid hsl(214.3 31.8% 91.4%);
        }
        
        .leaderboard-rank {
            font-weight: bold;
            color: hsl(222.2 47.4% 11.2%);
            margin-right: 10px;
        }

        .pseudo-input {
            margin-bottom: 20px;
        }

        .pseudo-input input {
            padding: 10px;
            border: 1px solid hsl(214.3 31.8% 91.4%);
            border-radius: 6px;
            margin-right: 10px;
            font-size: 16px;
        }

        .btn-load {
            padding: 10px 20px;
            background: hsl(222.2 47.4% 11.2%);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
        }

        .btn-load:hover {
            background: hsl(222.2 47.4% 11.2% / 0.9);
        }

        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header class="header">
        <h1 class="logo">JSQuizStarter</h1>
        <nav class="nav">
            <a href="/" class="dashboard-link">🏠 Accueil</a>
            <a href="/quiz" class="dashboard-link">🎮 Quiz</a>
        </nav>
    </header>

    <div class="dashboard-container">
        <h1 class="title">📊 Dashboard</h1>
        
        <div class="user-welcome" style="margin-bottom: 20px; text-align: center;">
            <h2 id="welcomeMessage" style="color: hsl(222.2 84% 4.9%); margin-bottom: 10px;">Chargement...</h2>
            <button id="logoutBtn" class="btn-load" onclick="logout()" style="background: hsl(0 72% 51%); display: none;">Se déconnecter</button>
        </div>

        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-value" id="totalGames">-</div>
                <div class="stat-label">Parties jouées</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="avgScore">-</div>
                <div class="stat-label">Score moyen</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="successRate">-</div>
                <div class="stat-label">Taux de réussite</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="lastGame">-</div>
                <div class="stat-label">Dernière partie</div>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="dashboard-card">
                <h3>📈 Mon Historique</h3>
                <div id="userHistory">
                    <p style="text-align: center; color: hsl(215.4 16.3% 46.9%);">
                        Entrez votre pseudo ci-dessus pour voir votre historique
                    </p>
                </div>
            </div>

            <div class="dashboard-card">
                <h3>🏆 Classement Général</h3>
                <div id="leaderboard">
                    <p style="text-align: center; color: hsl(215.4 16.3% 46.9%);">
                        Chargement du classement...
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Charger les données au chargement de la page
        document.addEventListener('DOMContentLoaded', function() {
            loadLeaderboard();
            checkAuthAndLoadData();
        });

        // Vérifier l'authentification et charger les données appropriées
        async function checkAuthAndLoadData() {
            try {
                const response = await fetch('/auth/check');
                const result = await response.json();
                
                if (result.success && result.user) {
                    // Utilisateur connecté
                    document.getElementById('welcomeMessage').textContent = `Bienvenue, ${result.user.name} !`;
                    document.getElementById('logoutBtn').style.display = 'inline-block';
                    loadUserDataByPseudo(result.user.name);
                } else {
                    // Utilisateur non connecté, rediriger vers login
                    document.getElementById('welcomeMessage').textContent = 'Accès non autorisé';
                    setTimeout(() => {
                        window.location.href = '/auth/login';
                    }, 2000);
                }
            } catch (error) {
                console.error('Erreur lors de la vérification de l\'authentification:', error);
                document.getElementById('welcomeMessage').textContent = 'Erreur de connexion';
                setTimeout(() => {
                    window.location.href = '/auth/login';
                }, 2000);
            }
        }

        // Fonction de déconnexion
        // async function logout() {
        //     try {
        //         const response = await fetch('/auth/logout', {
        //             method: 'POST',
        //             headers: {
        //                 'Content-Type': 'application/json',
        //             }
        //         });
                
        //         const result = await response.json();
        //         if (result.success) {
        //             alert('Déconnexion réussie');
        //             window.location.href = '/';
        //         } else {
        //             alert('Erreur lors de la déconnexion');
        //         }
        //     } catch (error) {
        //         console.error('Erreur lors de la déconnexion:', error);
        //         alert('Erreur de connexion');
        //     }
        // }

        // Charger les données par pseudo (pour utilisateur connecté)
        // Fonction de déconnexion
        async function logout() {
            try {
                const response = await fetch('/auth/logout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const result = await response.json();
                if (result.success) {
                    alert('Déconnexion réussie');
                    window.location.href = '/';
                } else {
                    alert('Erreur lors de la déconnexion');
                }
            } catch (error) {
                console.error('Erreur lors de la déconnexion:', error);
                alert('Erreur de connexion');
            }
        }

        // Charger les données par pseudo (pour utilisateur connecté)
        async function loadUserDataByPseudo(pseudo) {
            try {
                const response = await fetch(`/quiz/history?pseudo=${encodeURIComponent(pseudo)}`);
                const result = await response.json();

                if (result.success) {
                    displayUserHistory(result.data);
                    calculateUserStats(result.data);
                } else {
                    document.getElementById('userHistory').innerHTML = 
                        '<p style="text-align: center; color: hsl(215.4 16.3% 46.9%);">Aucune partie jouée pour le moment</p>';
                    resetStats();
                }
            } catch (error) {
                console.error('Erreur:', error);
                document.getElementById('userHistory').innerHTML = 
                    '<p style="text-align: center; color: red;">Erreur lors du chargement des données</p>';
            }
        }

        function displayUserHistory(history) {
            const historyDiv = document.getElementById('userHistory');
            
            if (history.length === 0) {
                historyDiv.innerHTML = '<p style="text-align: center; color: hsl(215.4 16.3% 46.9%);">Aucune partie jouée</p>';
                return;
            }

            let html = '';
            history.forEach(game => {
                const date = new Date(game.created_at).toLocaleDateString('fr-FR');
                const percentage = Math.round((game.score / game.total_questions) * 100);
                html += `
                    <div class="history-item">
                        <div>
                            <strong>${game.theme_name}</strong><br>
                            <small>${date}</small>
                        </div>
                        <div>
                            <strong>${game.score}/${game.total_questions}</strong><br>
                            <small>${percentage}%</small>
                        </div>
                    </div>
                `;
            });
            historyDiv.innerHTML = html;
        }

        function calculateUserStats(history) {
            if (history.length === 0) {
                resetStats();
                return;
            }

            const totalGames = history.length;
            const totalScore = history.reduce((sum, game) => sum + game.score, 0);
            const totalQuestions = history.reduce((sum, game) => sum + game.total_questions, 0);
            const avgScore = (totalScore / totalGames).toFixed(1);
            const successRate = Math.round((totalScore / totalQuestions) * 100);
            const lastGame = new Date(history[0].created_at).toLocaleDateString('fr-FR');

            document.getElementById('totalGames').textContent = totalGames;
            document.getElementById('avgScore').textContent = avgScore;
            document.getElementById('successRate').textContent = successRate + '%';
            document.getElementById('lastGame').textContent = lastGame;
        }

        function resetStats() {
            document.getElementById('totalGames').textContent = '-';
            document.getElementById('avgScore').textContent = '-';
            document.getElementById('successRate').textContent = '-';
            document.getElementById('lastGame').textContent = '-';
        }

        async function loadLeaderboard() {
            try {
                const response = await fetch('/quiz/leaderboard');
                const result = await response.json();

                if (result.success) {
                    displayLeaderboard(result.data);
                } else {
                    document.getElementById('leaderboard').innerHTML = 
                        '<p style="text-align: center; color: red;">Erreur lors du chargement du classement</p>';
                }
            } catch (error) {
                console.error('Erreur:', error);
                document.getElementById('leaderboard').innerHTML = 
                    '<p style="text-align: center; color: red;">Erreur de connexion</p>';
            }
        }

        function displayLeaderboard(leaderboard) {
            const leaderboardDiv = document.getElementById('leaderboard');
            
            if (leaderboard.length === 0) {
                leaderboardDiv.innerHTML = '<p style="text-align: center; color: hsl(215.4 16.3% 46.9%);">Aucune donnée</p>';
                return;
            }

            let html = '';
            leaderboard.forEach((player, index) => {
                const avgScore = parseFloat(player.avg_score).toFixed(1);
                const successRate = Math.round(player.success_rate);
                html += `
                    <div class="leaderboard-item">
                        <div>
                            <span class="leaderboard-rank">#${index + 1}</span>
                            <strong>${player.pseudo}</strong><br>
                            <small>${player.games_played} partie(s)</small>
                        </div>
                        <div>
                            <strong>${avgScore}</strong><br>
                            <small>${successRate}%</small>
                        </div>
                    </div>
                `;
            });
            leaderboardDiv.innerHTML = html;
        }


    </script>
</body>
</html>